APP_ADMIN_USERNAME=admin

# 二选一：
# 方式1：直接写明文密码（简单）
APP_ADMIN_PASSWORD=

# 方式2：写密码哈希（更安全，推荐）
APP_ADMIN_PASSWORD_HASH=

# 会话密钥，必须改成你自己的长随机字符串
APP_SESSION_SECRET=please-change-this-to-a-long-random-secret

# 你如果是 HTTPS 域名访问，改成 true
# 如果你现在还是 IP + HTTP 访问，先保持 false
APP_SESSION_HTTPS_ONLY=false

